import sqlite3

conn = sqlite3.connect("sales.db")
cursor = conn.cursor()

cursor.execute("""
CREATE TABLE IF NOT EXISTS sales (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    product TEXT,
    revenue INTEGER,
    date TEXT
)
""")

cursor.execute("DELETE FROM sales")  # optional reset

data = [
    ("Laptop", 50000, "2024-01-10"),
    ("Mobile", 30000, "2024-01-12"),
    ("Tablet", 20000, "2024-01-15"),
    ("Laptop", 70000, "2024-02-10"),
    ("Mobile", 40000, "2024-02-12"),
    ("Tablet", 25000, "2024-02-18")
]

cursor.executemany("INSERT INTO sales (product, revenue, date) VALUES (?, ?, ?)", data)

conn.commit()
conn.close()
